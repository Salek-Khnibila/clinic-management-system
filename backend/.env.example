# ─── Root .env ────────────────────────────────────────────────────────────────
# Vite lit les variables VITE_* automatiquement
# Le proxy Vite redirige /api → http://localhost:5000 (Flask)
VITE_API_URL=/api

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-long-random-string

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=gestion-clinique-secret-key-super-longue-pour-production-2024
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# ─── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gestion_clinique

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173